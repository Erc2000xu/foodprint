# Public runtime configuration. Do not put secrets in NEXT_PUBLIC_* variables.
# Keep this Vercel URL until ICP filing and the Tencent Cloud cutover are complete.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MAP_PROVIDER=amap
NEXT_PUBLIC_AMAP_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only configuration. Never commit the filled .env.local file.
AMAP_SECURITY_KEY=
# A separate AMap Web Service Key for server-side POI search. Never use NEXT_PUBLIC_.
AMAP_WEBSERVICE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STORAGE_PROVIDER=supabase
DATABASE_URL=

# Phase 1 bootstrap only; this is not a password and belongs in the local/private environment.
FOODPRINT_OWNER_EMAIL=owner@example.com
FOODPRINT_OWNER_PASSWORD=
FOODPRINT_GROUP_NAME=食迹 Foodprint
FOODPRINT_GROUP_SLUG=foodprint
